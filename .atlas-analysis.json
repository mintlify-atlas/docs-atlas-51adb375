  "keyFeatures": [
    "RFC 9420 compliant MLS protocol implementation",
    "End-to-end encrypted group messaging",
    "Multiple ciphersuite support (X25519, P-256, ChaCha20-Poly1305)",
    "Flexible trait-based architecture for crypto and storage providers",
    "Key package and credential management",
    "Group creation, joining, and member management",
    "Application message encryption and decryption",
    "Forward secrecy and post-compromise security",
    "Fork resolution for handling concurrent group state changes",
    "WebAssembly support for browser environments",
    "Built-in storage providers (memory, SQLite)",
    "External commit support for dynamic joining"
  ],
  "publicApiSurface": [
    "MlsGroup - Main group management API",
    "MlsGroupCreateConfig - Group configuration",
    "MlsGroupJoinConfig - Join configuration",
    "KeyPackage - Cryptographic key packages",
    "KeyPackageBundle - Key package with private keys",
    "CredentialWithKey - Identity credentials",
    "BasicCredential - Basic credential implementation",
    "Ciphersuite - Cryptographic algorithm suites",
    "MlsMessageIn - Incoming MLS messages",
    "MlsMessageOut - Outgoing MLS messages",
    "ProcessedMessage - Validated message content",
    "StagedWelcome - Staged group join from Welcome",
    "StagedCommit - Staged group state changes",
    "PublicGroup - Read-only group state",
    "LeafNode - Tree leaf node representation",
    "Capabilities - Member capabilities",
    "Extension - Protocol extensions",
    "OpenMlsProvider - Provider trait for dependencies",
    "OpenMlsCrypto - Cryptographic operations trait",
    "StorageProvider - Key/group storage trait"
  ]
}
